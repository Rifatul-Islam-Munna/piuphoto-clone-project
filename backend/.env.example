# MongoDB
MONGODB_URL=mongodb://localhost:27017/piuphoto

# JWT
ACCESS_TOKEN=your-super-secret-jwt-key-change-in-production

# MinIO (Object Storage)
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET_NAME=piuphoto-public-bucket

# Admin Credentials
ADMIN_PHONE=01712345678
ADMIN_PASSWORD=admin123

# CORS
CORS_ORIGIN=http://localhost:5173

# Server
PORT=4000

# Qdrant Face Search
QDRANT_URL=http://localhost:6333
FACE_DETECTION_ENDPOINT_URL=PASTE_MY_ENDPOINT_HERE
FACE_CLUSTER_DISTANCE=0.55
FACE_MATCH_DISTANCE=0.95
FACE_SEARCH_SCAN_LIMIT=10000
FAL_KEY=
IS_WEBHOOK=false
FAL_WEBHOOK_URL=https://api.example.com/eventImage/fal-webhook
