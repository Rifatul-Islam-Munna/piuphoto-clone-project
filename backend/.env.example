# MongoDB
MONGODB_URL=mongodb://localhost:27017/piuphoto

# JWT
ACCESS_TOKEN=your-super-secret-jwt-key-change-in-production

# MinIO (Object Storage)
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=your-access-key
MINIO_SECRET_KEY=your-secret-key
MINIO_BUCKET_NAME=piuphoto-public-bucket

# Admin Credentials
ADMIN_PHONE=01712345678
ADMIN_PASSWORD=admin123

# CORS
CORS_ORIGIN=http://localhost:5173

# Server
PORT=4000

# Qdrant Face Search
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_FACE_COLLECTION=event_faces
FACE_API_MODEL_PATH=./models/face-api
FACE_DETECTOR=tiny
FACE_IMAGE_MAX_WIDTH=1280
FACE_INDEX_CONCURRENCY=1
FACE_DETECT_MIN_CONFIDENCE=0.5
